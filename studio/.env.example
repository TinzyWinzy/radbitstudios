# =============================================================================
# Radbit Studios — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# --- Firebase Config (required for build + runtime) ---
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Firebase Admin (server-side). Either provide a JSON service account key inline:
FIREBASE_SERVICE_ACCOUNT_KEY={"project_id":"...","private_key":"...","client_email":"...",...}
# OR set GOOGLE_APPLICATION_CREDENTIALS to a file path (local dev only).
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# --- Site URL (required for SEO, sitemap, email links) ---
FRONTEND_URL=https://radbitstudios.co.zw
NEXT_PUBLIC_FRONTEND_URL=https://radbitstudios.co.zw

# --- Supabase PostgreSQL (required for tender/news scraper + RAG) ---
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# --- AI / LLM (at least one provider key required) ---
GEMINI_API_KEY=
# GOOGLE_GENAI_API_KEY=  # Alternative Gemini key format
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxx

# --- Payments ---
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_AUTH_EMAIL=
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
ECOCASH_API_KEY=
ECOCASH_API_URL=
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
INNBUCKS_API_KEY=
INNBUCKS_API_SECRET=
INNBUCKS_API_URL=

# --- WhatsApp Cloud API ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# --- Push Notifications (Web Push / VAPID) ---
VAPID_PRIVATE_KEY=

# --- Analytics ---
NEXT_PUBLIC_GA_ID=G-xxxxx

# --- External APIs ---
NEWSAPI_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Rate Limiting (Upstash Redis) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Admin / Internal ---
ADMIN_WHATSAPP=+2637xxxxxxxx
CRON_SECRET=local-test-secret
INTERNAL_API_KEY=local-test-secret
API_URL=http://localhost:3000

# --- Logging ---
LOG_LEVEL=debug
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
