# Gemini AI (required at runtime for AI features)
# GEMINI_API_KEY=

# Firebase configuration (client-side - inlined by Next.js at build time)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Encryption key for PII (AES-256-GCM) - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────
# PAYMENT PROVIDERS
# All are server-side only (never inline in client)
# ─────────────────────────────────────────────────

# Stripe (card payments, worldwide fallback)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# EcoCash (Zimbabwe mobile money) — server-side only
ECOCASH_API_KEY=
ECOCASH_MERCHANT_CODE=

# PayNow Zimbabwe — server-side only
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_AUTH_EMAIL=

# PayFast South Africa — server-side only
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=

# ─────────────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────────────

# WhatsApp Business Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio SMS (fallback)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─────────────────────────────────────────────────
# AI GATEWAY (multi-model, Redis-budgeted)
# ─────────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Firebase Admin SDK — path to service account key (server-side only)
# GOOGLE_APPLICATION_CREDENTIALS=

# ─────────────────────────────────────────────────
# STAGING ENVIRONMENT (separate Firebase project)
# ─────────────────────────────────────────────────
STAGING_FIREBASE_APP_ID=
STAGING_FIREBASE_API_KEY=
STAGING_FIREBASE_MESSAGING_SENDER_ID=

# ─────────────────────────────────────────────────
# SENTRY (error tracking & monitoring)
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=radbit-studios
SENTRY_PROJECT=sme-hub
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────
# INFRASTRUCTURE
# ─────────────────────────────────────────────────
# Used by sitemap, robots.txt and all JSON-LD structured data.
# Should match your live production URL (no trailing slash).
FRONTEND_URL=http://localhost:9002
API_URL=http://localhost:9002/api
# DATABASE_URL=postgresql://user:pass@localhost:5432/radbit
# REDIS_URL=redis://localhost:6379
# MEILISEARCH_URL=http://localhost:7700
