rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny — no access unless explicitly granted below.
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── REQUEST QUOTA / RATE LIMITING ──────────────────────────────────────
    // Per-IP backstop against DB-level bypass. Real rate limiting happens at
    // the API gateway / App Hosting layer; this is a defence-in-depth guard.
    match /rate_limit_counters/{counterId} {
      allow read, write: if false;
    }

    // ─── OTP LOCKOUTS ─────────────────────────────────────────────────────────
    match /lockouts/{lockoutId} {
      allow read, write: if false;
    }

    // ─── USERS ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow list: if request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── ASSESSMENTS ─────────────────────────────────────────────────────────
    match /assessments/{assessmentId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow get, delete: if request.auth.uid == resource.data.userId;
      allow list: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ─── GENERATIONS (AI AGENT HISTORY) ───────────────────────────────────────
    match /generations/{generationId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read, delete: if request.auth.uid == resource.data.userId;
      allow list: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ─── BUDGETS ──────────────────────────────────────────────────────────────
    match /budgets/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // ─── EXPORT ASSESSMENTS ─────────────────────────────────────────────────
    match /export_assessments/{assessmentId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow get, delete: if request.auth.uid == resource.data.userId;
      allow list: if request.auth != null;
    }

    // ─── REFERRAL CODES ────────────────────────────────────────────────────
    // Allow anyone to read a referral code by ID to verify it exists.
    // Only the owner can create their own code (userId must match).
    match /referral_codes/{code} {
      allow get: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.userId;
      // Transactions update usageCount — allow if authenticated & code belongs to someone
      allow update: if request.auth != null;
      allow list: if false;
    }

    // ─── RAG KNOWLEDGE BASE ─────────────────────────────────────────────────
    // Used by AI flows (server-side). Readable by authenticated users for
    // vector search queries. Only server-side writes (no client creates).
    match /rag_documents/{docId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if false; // server-side only
    }
    match /rag_chunks/{chunkId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if false; // server-side only
    }

    // ─── INVOICES ─────────────────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow get: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // ─── BOOKMARKS ─────────────────────────────────────────────────────────────
    match /users/{userId}/bookmarks/{bookmarkId} {
      allow read, write, delete: if request.auth.uid == userId;
    }

    // ─── SCRAPER DATA (server-side only via Admin SDK) ──────────────────────
    match /scraper_tenders/{docId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if false; // server-side only via Admin SDK
    }
    match /scraper_news/{docId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if false; // server-side only via Admin SDK
    }
    match /scraper_sync_log/{docId} {
      allow read, write: if false; // internal only
    }

    // ─── WHATSAPP SESSIONS (server-side only via Admin SDK) ─────────────────
    match /whatsapp_sessions/{sessionId} {
      allow read, write: if false; // server-side only via Admin SDK
    }

    // ─── SCORED ITEMS (server-side only via Admin SDK) ─────────────────────
    match /scored_items/{contentId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if false; // server-side only via Admin SDK
    }

    // ─── SOURCE DISCOVERY (server-side only via Admin SDK) ────────────────
    match /active_sources/{sourceId} {
      allow read: if request.auth != null;
      allow write: if false; // server-side only
    }
    match /discovered_sources/{sourceId} {
      allow read: if request.auth != null;
      allow write: if false; // server-side only
    }
    match /source_health/{sourceId} {
      allow read: if request.auth != null;
      allow write: if false; // server-side only
    }

    // ─── BLOG POSTS ──────────────────────────────────────────────────────────
    // Public read for published posts. Client-side blog listing reads published
    // posts with get-by-id. Admin dashboard uses adminDb for writes.
    match /blog_posts/{postId} {
      allow get: if resource.data.published == true || request.auth != null;
      allow list: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.role in ['admin', 'super_admin'];
      allow update, delete: if request.auth != null && request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── FAQ ITEMS ────────────────────────────────────────────────────────────
    // Public read for published items. Admin dashboard manages content.
    match /faq_items/{itemId} {
      allow get: if resource.data.published == true || request.auth != null;
      allow list: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── GUIDES ───────────────────────────────────────────────────────────────
    // Public read/list for published guides. Admin dashboard manages content.
    match /guides/{guideId} {
      allow get: if resource.data.published == true || request.auth != null;
      allow list: if resource.data.published == true || request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── SEO PAGES ────────────────────────────────────────────────────────────
    // Public read for published pages. Admin dashboard manages content.
    match /seo_pages/{pageId} {
      allow get: if resource.data.published == true || request.auth != null;
      allow list: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── COMMUNITY THREADS ────────────────────────────────────────────────────
    match /threads/{threadId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.authorId;
      // Any authenticated user can update only replyCount and lastReplyAt.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['replyCount', 'lastReplyAt']);

      // THREAD REPLIES
      match /replies/{replyId} {
        allow get, list, create: if request.auth != null;
        // Only the thread author can update a reply (mark best answer).
        allow update: if request.auth.uid
          == get(/databases/$(database)/documents/threads/$(threadId)).data.authorId;
      }
    }

    // ─── NOTIFICATIONS (IN-APP) ──────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow list: if request.auth != null;
    }

    // ─── AFFILIATE CLICK LOGS ────────────────────────────────────────────────
    // Written server-side via Admin SDK (redirect route). No client access.
    match /affiliate_clicks/{clickId} {
      allow read, write: if false;
    }

    // ─── PAYMENT RETRIES (server-side only via Admin SDK) ─────────────────
    match /payment_retries/{retryId} {
      allow read, write: if false;
    }

    // ─── PRAZ COMPLIANCE DOCUMENTS ──────────────────────────────────────────
    // Users can read their own documents; server-side handles uploads/deletes.
    match /praz_documents/{docId} {
      allow get, list: if request.auth.uid == resource.data.userId;
      allow create, update, delete: if false; // server-side only via Admin SDK
    }

    // ─── PARTNER CODES (SMEAZ / ZNCC / CZI) ────────────────────────────────
    // Readable for validation; writes are server-side only.
    match /partner_codes/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create, update, delete: if false;
    }

    // ─── NEWSLETTER SUBSCRIPTIONS ───────────────────────────────────────────
    // Users can read/update their own subscription; server-side creates.
    match /newsletter_subscriptions/{userId} {
      allow get: if request.auth.uid == userId;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
      allow list: if false;
    }

    // ─── CONVERSATIONS (DIRECT MESSAGING) ────────────────────────────────────
    match /conversations/{conversationId} {
      allow get: if request.auth.uid in resource.data.participants;
      allow list: if request.auth != null;
      allow create: if request.auth.uid in request.resource.data.participants;
      allow update: if request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lastMessage']);

      match /messages/{messageId} {
        allow read, list: if request.auth.uid
          in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // ─── AI CHAT THREADS (per-user conversations with AI Mentor) ───────────
    // Server-side writes via Admin SDK. Clients can read their own threads.
    match /conversations/{userId}/threads/{threadId} {
      allow read, list: if request.auth.uid == userId;
      allow create, update, delete: if false; // server-side only via Admin SDK

      match /messages/{messageId} {
        allow read, list: if request.auth.uid == userId;
        allow create, update, delete: if false; // server-side only via Admin SDK
      }
    }

    // ─── AI SEMANTIC CACHE ─────────────────────────────────────────────────
    // Server-side only. No client access.
    match /ai_semantic_cache/{docId} {
      allow read, list: if false;
      allow create, update, delete: if false;
    }

    // ─── BRUTE FORCE ATTEMPTS ──────────────────────────────────────────────
    // Server-side only. No client access.
    match /bruteforce_attempts/{docId} {
      allow read, list: if false;
      allow create, update, delete: if false;
    }

    // ─── RATE LIMIT COUNTERS ───────────────────────────────────────────────
    // Server-side only. No client access.
    match /ratelimit_counters/{docId} {
      allow read, list: if false;
      allow create, update, delete: if false;
    }

    // ─── PROJECTS (Client Consultancy Projects) ─────────────────────────
    // Clients read their own; admins read all; admin SDK handles writes.
    match /projects/{projectId} {
      allow get: if request.auth.uid == resource.data.clientId
                  || request.auth.token.role in ['admin', 'super_admin'];
      allow list: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.clientId
                     || request.auth.token.role in ['admin', 'super_admin'];
      allow update, delete: if request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── PROJECT TASKS ─────────────────────────────────────────────────────
    match /project_tasks/{taskId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── ONBOARDING CHECKLISTS ────────────────────────────────────────────
    match /onboarding_checklists/{checklistId} {
      allow get: if request.auth.uid == resource.data.userId
                  || request.auth.token.role in ['admin', 'super_admin'];
      allow list: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.userId
                     || request.auth.token.role in ['admin', 'super_admin'];
      allow update: if request.auth.uid == resource.data.userId
                     || request.auth.token.role in ['admin', 'super_admin'];
      allow delete: if request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── CLIENT NOTES (admin-only) ────────────────────────────────────────
    match /client_notes/{noteId} {
      allow get, list: if request.auth.token.role in ['admin', 'super_admin'];
      allow create: if request.auth.token.role in ['admin', 'super_admin'];
      allow delete: if request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── RETI: THREAT ASSESSMENTS ──────────────────────────────────────────
    // Public read for published assessments (served via SSR, but allow direct reads).
    // Admin-only write (generated server-side via cron/API).
    match /threat_assessments/{slug} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if request.auth.token.role in ['admin', 'super_admin'];
    }

    // ─── RETI: MONITOR SOURCES ─────────────────────────────────────────────
    // Public read for listing source status. Admin-only write.
    match /reti_monitor_sources/{docId} {
      allow get, list: if true;
      allow create, update, delete: if request.auth.token.role in ['admin', 'super_admin'];
    }
  }
}